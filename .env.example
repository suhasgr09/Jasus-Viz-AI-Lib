# ── AI Provider API Keys ──────────────────────────────────────────────────────
# Fill in the keys for the providers you want to use. All are optional.
# At minimum, set GITHUB_TOKEN to use the Copilot (gpt-4o) provider.

# GitHub Copilot — recommended primary provider
# Generate at https://github.com/settings/tokens  (scope: models:read)
GITHUB_TOKEN=

# Google Gemini — free tier available via Google AI Studio
GEMINI_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenAI GPT-4o
OPENAI_API_KEY=
